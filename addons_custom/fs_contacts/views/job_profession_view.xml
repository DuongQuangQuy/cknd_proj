<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="job_profession_tree_view" model="ir.ui.view">
            <field name="name">job.profession.tree.view</field>
            <field name="model">job.profession</field>
            <field name="arch" type="xml">
                <tree editable="bottom">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="job_profession_action" model="ir.actions.act_window">
            <field name="name">Ngành nghề</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">job.profession</field>
            <field name="view_mode">tree</field>
        </record>


    </data>
</odoo>