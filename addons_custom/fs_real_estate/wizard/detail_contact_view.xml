<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="detail_contact_form" model="ir.ui.view">
            <field name="name">detail.contact.form</field>
            <field name="model">detail.contact</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="number_house" readonly="1"/>
                                <field name="street_id" readonly="1"/>
                                <field name="address_ward_district_show" readonly="1"/>
                                <field name="contact" readonly="1"/>
                                <field name="partner_ids" widget="many2many_tags" invisible="1"/>
                                <field name="estate_id"  invisible="1"/>
                            </group>
                            <group>
                                <field name="job_profession_id" readonly="1"/>
                                <field name="source_image" readonly="1"/>
                                <field name="source_image_partner_ids" widget="many2many_tags" readonly="1"/>
                                <field name="source_estate_partner_ids" widget="many2many_tags" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Nhà đất">
                                <field name="estate_ids" widget="one2many_selectable" readonly="1">
                                    <tree delete="1" >
                                        <field name="image_avatar" widget="image" class="oe_avatar"/>
                                        <field name="date_show" widget="html"/>
                                        <field name="code_demand_secondary_show" widget="html"/>
                                        <field name="type_style_direction_show" widget="html"/>
                                        <field name="number_house"/>
                                        <field name="street_id"/>
                                        <field name="address_ward_district_show"/>
                                        <field name="horizontal_length_use_area_show" widget="html"/>
                                        <field name="total_price" />
                                        <field name="structure_ids" widget="many2many_tags"/>
                                        <field name="note"/>
                                        <field name="deposit"/>
                                        <field name="paid"/>
                                        <field name="fee"/>
                                        <button string="!" name="action_show_advertising_sample" type="object" class="oe_highlight" style="min-width:30px; min-heigth:30px;"/>
                                        <button name="action_update_date_entry"
                                                type="object"
                                                icon="fa-refresh"
                                                class="oe_highlight"/>
                                        <button string=" " name="action_detail_contact_view" type="object" icon="fa-edit" class="oe_highlight" style="min-width:30px; min-heigth:30px;"/>
                                        <button string=" " name="action_greeting_customer_estate_views" type="object" icon="fa-users" class="oe_highlight" style="min-width:30px; min-heigth:30px;"/>

                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button string="Chào nhà" name="action_greeting_customer_estate_views" type="object" class="oe_highlight" />
                        <button string="Hủy" class="btn-secondary" special="cancel" data-hotkey="z" />
                    </footer>
                </form>
            </field>
        </record>

