<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="update_address_form" model="ir.ui.view">
            <field name="name">update.address.form</field>
            <field name="model">update.address</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
<!--                            <div>-->
                                <h1 style="text-align: center;">Cập nhật địa chỉ</h1>
<!--                            </div>-->
                        <br/>
                            <group>
                                <group string="Chuyển từ">
                                    <field name="street_from_id"/>
                                    <field name="ward_from_id"/>
                                    <field name="district_from_id" />
                                    <field name="city_from_id" />
                                    <field name="number_house_from" />
                                </group>
                                <group  string="Chuyển qua">
                                    <field name="street_to_id"/>
                                    <field name="ward_to_id"/>
                                    <field name="district_to_id" />
                                    <field name="city_to_id" />
                                    <field name="number_house_to" />
                                </group>

                            </group>

                        <button name="search_address" string="Địa chỉ nhà" type="object" class="oe_highlight"/>
                        <button name="update_address" string="Chuyển địa chỉ" type="object" class="oe_highlight" style="margin-left:10px"/>

                        <field name="line_ids" widget="one2many_selectable" style="margin-top:10px">
                            <tree create="0" >
                                <field name="date_show" widget="html"/>
                                    <field name="code_demand_secondary_show" widget="html"/>
                                    <field name="type_style_direction_show" widget="html"/>

<!--                                    <field name="address_show" widget="html"/>-->
                                    <field name="number_house"/>
                                    <field name="street_id"/>
                                    <field name="address_ward_district_show"/>

                                    <field name="horizontal_length_use_area_show" widget="html"/>
                                    <field name="total_price" />
                                    <field name="structure_ids" widget="many2many_tags"/>
                                    <field name="note"/>
                                    <field name="deposit"/>
                                    <field name="paid"/>
                                    <field name="fee"/>
                            </tree>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_update_address_form" model="ir.actions.act_window">
            <field name="name">Cập nhật địa chỉ</field>
            <field name="res_model">update.address</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="update_address_form"/>
            <field name="target">inline</field>
        </record>

<!--        <menuitem id="delivery_profit_report_menu"-->
<!--                  name="Báo cáo lợi nhuận giao hàng"-->
<!--                  parent="account.menu_finance_reports"-->
<!--                  action="action_delivery_profit_report"-->
<!--                  sequence="2" />-->
<!--                  groups="base.group_user"-->
    </data>
</odoo>