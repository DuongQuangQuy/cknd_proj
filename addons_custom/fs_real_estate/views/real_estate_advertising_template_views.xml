<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="real_estate_advertising_template_view_tree" model="ir.ui.view">
        <field name="name">real.estate.advertising.template.view.tree</field>
        <field name="model">real.estate.advertising.template</field>
        <field name="arch" type="xml">
            <tree string="">
                <field name="name" string='Key'/>
            </tree>
        </field>
    </record>

    <record id="real_estate_advertising_template_view_form" model="ir.ui.view">
        <field name="name">real.estate.advertising.template.view.form</field>
        <field name="model">real.estate.advertising.template</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <field name="name" />
                    </group>
                    <notebook>
                        <page name="text_template" string="Text template">
                            <field name="advertising_template" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="real_estate_advertising_template_action" model="ir.actions.act_window">
        <field name="name">Update ad template</field>
        <field name="res_model">real.estate.advertising.template</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
