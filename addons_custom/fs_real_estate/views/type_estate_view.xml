<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="type_estate_tree_view" model="ir.ui.view">
            <field name="name">type.estate.tree.view</field>
            <field name="model">type.estate</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="color"/>
                    <field name="note"/>
                </tree>
            </field>
        </record>

        <record id="type_estate_view_form" model="ir.ui.view">
        <field name="name">type.estate.view.form</field>
        <field name="model">type.estate</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

        <record id="type_estate_action" model="ir.actions.act_window">
            <field name="name">Loại</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">type.estate</field>
            <field name="view_mode">tree,form</field>
        </record>


    </data>
</odoo>