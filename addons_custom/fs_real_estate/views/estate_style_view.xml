<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="estate_style_tree_view" model="ir.ui.view">
            <field name="name">estate.style.tree.view</field>
            <field name="model">estate.style</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="group_style_id"/>
                </tree>
            </field>
        </record>

        <record id="estate_style_view_form" model="ir.ui.view">
            <field name="name">estate.style.view.form</field>
            <field name="model">estate.style</field>
            <field name="arch" type="xml">
                <form string="">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="group_style_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="estate_style_action" model="ir.actions.act_window">
            <field name="name">Kiểu</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">estate.style</field>
            <field name="view_mode">tree,form</field>
        </record>


    </data>
</odoo>