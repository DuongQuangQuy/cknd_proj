<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="real_estate_search_expired_view_form" model="ir.ui.view">
            <field name="name">real.estate.search.expired.view.form</field>
            <field name="model">real.estate.search.expired</field>
            <field name="arch" type="xml">
                <form string="" class="o_estate_search_form_view">
<!--                    <header>-->
<!--                        -->
<!--                    </header>-->
                    <sheet >
                        <group>
                            <group string="Liên hệ">
                                <field name="code"/>
                                <field name="contact"/>
                                <field name="note"/>
                            </group>
                            <group string="Diện tích - Giá cả">
                                <table>
	                				<tr>
	                					<th>#</th><th>Từ</th><th>Tới</th><th>#</th><th>Từ</th><th>Tới</th>
	                				</tr>
	                				<tr>
	                					<th>Ngang:</th><td><field name="horizontal_from"/></td><td><field name="horizontal_to"/></td>
	                					<th>Dài: </th><td><field name="length_from"/></td><td><field name="length_to"/></td>
	                				</tr>
	                				<tr>
	                					<th>DTKV: </th><td><field name="acreage_area_from"/></td><td><field name="acreage_area_to"/></td>
	                					<th>DTSD: </th><td><field name="acreage_use_from"/></td><td><field name="acreage_use_to"/></td>
	                				</tr>
	                				<tr>
	                					<th>Giá: </th>
	                					<td><field name="total_price_from"/></td>
	                					<td><field name="total_price_to"/></td>

<!--	                					<th><label for="currency_id" invisible="1"></label></th>-->
<!--	                					<td colspan="2">-->
<!--	                						<field name='currency_id'  invisible="1" required="1" options="{'no_create': True, 'no_open': True}" />-->
<!--               							</td>-->
	                				</tr>
	                			</table>

                            </group>
                        </group>
                        <group>
                            <group>
                                <table style="width:90% !important;">
	                				<tr>
	                					<th>#</th><th>Từ</th><th>Tới</th>
	                				</tr>
	                				<tr>
	                					<th>Ngày nhập:</th><td><field name="date_entry_from"/></td><td><field name="date_entry_to"/></td>
	                				</tr>
                                    <tr>
	                					<th>Ngày hết hạn HĐ: </th><td><field name="date_contract_exp_from"/></td><td><field name="date_contract_exp_to"/></td>
	                				</tr>
                                    <tr>
	                					<th>Ngày cập nhật: </th><td><field name="date_updated_from"/></td><td><field name="date_updated_to"/></td>
	                				</tr>
	                			</table>
                            </group>
                            <group>
                                <br/>
                                <field name="source_estate_partner_id"/>
                                <field name="source_image"/>
                            </group>
                        </group>
                        <group>
                            <group string="Vị trí">
                                <field name="city_ids"    options="{'no_open': True,'no_create_edit': True, 'no_create': True }" widget="many2many_tags"/>
                                <field name="district_ids"
                                         options="{'no_open': True,'no_create_edit': True, 'no_create': True }"
                                         widget="many2many_tags"/>
                                <field name="ward_ids"
                                    options="{'no_open': True, 'no_create_edit': True, 'no_create': True }"
                                      widget="many2many_tags"/>

                                <label for="number_house_from" string="Số nhà"/>
                                <div colspan="1" style="display: flex; width: 98%;">
                                    <div style="flex: 0 0 49%; margin-right: 10px;">
                                        <field name="number_house_from" placeholder="Số nhà từ" nolabel="1" style="width: 100%;"/>
                                    </div>
                                    <div style="flex: 0 0 49%;">
                                        <field name="number_house_to" placeholder="Số nhà đến" nolabel="1" style="width: 100%;"/>
                                    </div>
                                </div>
                                <field name="street_ids"
                                            options="{'no_open': True, 'no_create_edit': True, 'no_create': True}"
                                            class="street_select" placeholder="Chọn Đường" style="width: 100%;" widget="many2many_tags"/>
                                <field name="group_direction_id" />
                                <field name="way_ids" widget="many2many_tags"/>
                                <field name="type_number" />
                            </group>
                            <group string="Cấu trúc">
                                <field name="type_estate_ids" widget="many2many_tags"/>
                                <field name="group_style_id" />
                                <field name="style_ids" widget="many2many_tags"/>
                                <field name="type_demand_ids" widget="many2many_tags"/>
                                <field name="secondary_form_ids" widget="many2many_tags"/>
                                <field name="structure_ids" widget="many2many_tags"/>
                                <field name="job_profession_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </sheet>
                   <div style="text-align: right;  margin-right: 265px;">
                        <button string=" Search" name="action_search_real_estate" type="object" class="oe_highlight"
                                style="padding: 8px 18px; font-size: 15px;">
                            <i class="fa fa-search" aria-hidden="true" style="margin-right: 5px;"></i>
                        </button>
                   </div>
                    <notebook>
                        <page string="Nhà đất">
                            <field name="real_estate_ids" readonly="1">
                                <tree>
                                    <field name="image_avatar" widget="image" class="oe_avatar"/>
                                    <field name="date_show" widget="html"/>
                                    <field name="code_demand_secondary_show" widget="html"/>
                                    <field name="type_style_direction_show" widget="html"/>
                                    <field name="number_house"/>
                                    <field name="street_id"/>
                                    <field name="address_ward_district_show"/>
<!--                                    <field name="address_show" widget="html"/>-->
                                    <field name="horizontal_length_use_area_show" widget="html"/>
                                    <field name="total_price" />
                                    <field name="structure_ids" widget="many2many_tags"/>
                                    <field name="note"/>
                                    <field name="deposit"/>
                                    <field name="paid"/>
                                    <field name="fee"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </form>
            </field>
        </record>

        <record id="action_real_estate_search_expired" model="ir.actions.act_window">
            <field name="name">Tìm kiếm nhà đất hết hạn</field>
            <field name="res_model">real.estate.search.expired</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="real_estate_search_expired_view_form"/>
            <field name="target">inline</field>
        </record>

    </data>
</odoo>