<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="group_style_tree_view" model="ir.ui.view">
            <field name="name">group.style.tree.view</field>
            <field name="model">group.style</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="style_ids" widget="many2many_tags"/>
                </tree>
            </field>
        </record>

        <record id="group_style_view_form" model="ir.ui.view">
            <field name="name">group.style.view.form</field>
            <field name="model">group.style</field>
            <field name="arch" type="xml">
                <form string="">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="style_ids" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="group_style_action" model="ir.actions.act_window">
            <field name="name">Nhóm kiểu</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">group.style</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>