<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="estate_way_tree_view" model="ir.ui.view">
            <field name="name">estate.way.tree.view</field>
            <field name="model">estate.way</field>
            <field name="arch" type="xml">
                <tree editable="bottom">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="estate_way_action" model="ir.actions.act_window">
            <field name="name">Lối đi</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">estate.way</field>
            <field name="view_mode">tree</field>
        </record>

    </data>
</odoo>