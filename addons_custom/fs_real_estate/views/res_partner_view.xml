<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_partner_tree_inherit_view_fs_contacts" model="ir.ui.view">
        <field name="name">view.partner.tree.inherit.view.fs.contacts</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="fs_contacts.view_partner_tree_inherit_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='display_name']" position="before">
                <field name="is_employee" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="res_partner_form_inherit_view_fs_contacts" model="ir.ui.view">
        <field name="name">view.partner.form.inherit.view.fs.contacts</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="fs_contacts.res_partner_form_inherit_view"/>
        <field name="arch" type="xml">
           <xpath expr="//sheet" position="before">
                <header>
                    <button name="button_add_demand_estate_search" type="object" string="Thêm yêu cầu tìm kiếm" class="oe_highlight"/>
                </header>
            </xpath>

            <xpath expr="//field[@name='type_contact']" position="before">
                <field name="is_vip" />
                <field name="is_hide_mobile" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='mobile']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_hide_mobile', '=', True)]}</attribute>
            </xpath>

            <xpath expr="//field[@name='mobile_2']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_hide_mobile', '=', True)]}</attribute>
            </xpath>

            <xpath expr="//field[@name='mobile_3']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_hide_mobile', '=', True)]}</attribute>
            </xpath>

            <xpath expr="//field[@name='mobile_4']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_hide_mobile', '=', True)]}</attribute>
            </xpath>

            <xpath expr="//page[@name='contact_addresses']" position="after">
                <page name="real_estate" string="Nhà đất" >
                    <field name="estate_ids" readonly="1">
                        <tree>
                            <field name="date_show" widget="html"/>
                            <field name="code_demand_secondary_show" widget="html"/>
                            <field name="type_style_direction_show" widget="html"/>
                            <field name="number_house"/>
                            <field name="street_id"/>
                            <field name="address_ward_district_show"/>
<!--                                <field name="address_show" widget="html"/>-->
                            <field name="horizontal_length_use_area_show" widget="html"/>
                            <field name="total_price" />
                            <field name="structure_ids" widget="many2many_tags"/>
                            <field name="note"/>
                            <field name="deposit"/>
                            <field name="paid"/>
                            <field name="fee"/>
                        </tree>
                    </field>
                </page>
                <page name="demand_estate_search" string="Yêu cầu tìm kiếm">
                    <field name="demand_estate_search_ids" readonly="1">
                        <tree>
                            <field name="date_request"/>
                            <field name="user_id"/>
                            <field name="partner_id"/>
                            <field name="street_ids" widget="many2many_tags"/>
                            <field name="ward_ids" widget="many2many_tags"/>
                            <field name="district_ids" widget="many2many_tags"/>
                            <field name="city_ids" widget="many2many_tags"/>
                            <field name="state"/>
                        </tree>
                    </field>
                </page>
                <page name="offering_estate" string="Các căn đã chào">
                    <field name="offering_estate_ids" readonly="1">
                        <tree>
                            <field name="create_date" string="Chào lúc"/>
                            <field name="partner_id" />
                            <field name="customer_id" />
                            <field name="demand_id" />
                            <field name="search_demand_id" string="Theo yêu cầu"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <record id="res_partner_estate_greeted_view_form" model="ir.ui.view">
            <field name="name">res.partner.estate.greeted.view.form</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <form string="">
                    <sheet>
                        <group>
                            <group>
                                <field name="code" readonly="1"/>
                                <field name="name" readonly="1"/>
                            </group>
                            <group>

                            </group>
                        </group>
                        <notebook>
                             <page name="offering_estate" string="Các căn đã chào">
                                <field name="offering_estate_ids" readonly="1">
                                    <tree>
                                        <field name="create_date" string="Chào lúc"/>
                                        <field name="partner_id" />
                                        <field name="demand_id" />
                                        <field name="search_demand_id" string="Theo yêu cầu"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    <record model="ir.actions.act_window" id="action_create_res_partner">
			 <field name="name">Tạo mới liên hệ</field>
			 <field name="res_model">res.partner</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="base.view_partner_form"/>

<!--            <field name="target">new</field>-->
		 </record>

</odoo>