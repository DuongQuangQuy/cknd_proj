                                    <div style="flex: 0 0 49%; margin-right: 10px;">
                                        <field name="number_house_from" placeholder="Số nhà từ" nolabel="1" style="width: 100%;"/>
                                    </div>
                                    <div style="flex: 0 0 49%;">
                                        <field name="number_house_to" placeholder="Số nhà đến" nolabel="1" style="width: 100%;"/>
                                    </div>
                                </div>
                                <field name="street_ids"
                                            options="{'no_open': True, 'no_create_edit': True, 'no_create': True}"
                                            class="street_select" placeholder="Chọn Đường" style="width: 100%;" widget="many2many_tags"/>
<!--                                <field name="group_direction_id" />-->
                                <field name="way_ids" widget="many2many_tags"/>
                                <field name="type_number" />
