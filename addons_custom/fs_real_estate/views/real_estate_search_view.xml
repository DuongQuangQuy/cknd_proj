	                				</tr>
	                				<tr>
	                					<th>Ngang:</th><td><field name="horizontal_from"/></td><td><field name="horizontal_to"/></td>
	                					<th>Dài: </th><td><field name="length_from"/></td><td><field name="length_to"/></td>
	                				</tr>
	                				<tr>
	                					<th>DTKV: </th><td><field name="acreage_area_from"/></td><td><field name="acreage_area_to"/></td>
	                					<th>DTSD: </th><td><field name="acreage_use_from"/></td><td><field name="acreage_use_to"/></td>
	                				</tr>
	                				<tr>
	                					<th>Giá: </th>
	                					<td><field name="total_price_from"/></td>
	                					<td><field name="total_price_to"/></td>

<!--	                					<th><label for="currency_id" invisible="1"></label></th>-->
