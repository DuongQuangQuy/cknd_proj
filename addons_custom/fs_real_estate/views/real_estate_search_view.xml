                                <field name="ward_ids"
                                    options="{'no_open': True, 'no_create_edit': True, 'no_create': True }"
                                      widget="many2many_tags"/>
                                  <field name="number_house" />
                                <label for="number_house_from" string="Số nhà(Kiểu số)"/>
