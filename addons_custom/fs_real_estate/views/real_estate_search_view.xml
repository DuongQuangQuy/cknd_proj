                            </group>
                        </group>
                        <group>
                            <group string="Vị trí">
                                <field name="city_ids"    options="{'no_open': True,'no_create_edit': True, 'no_create': True }" widget="many2many_tags"/>
                                <field name="district_ids"
                                         options="{'no_open': True,'no_create_edit': True, 'no_create': True }"
