<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="real_estate_tree_view" model="ir.ui.view">
            <field name="name">real.estate.py.tree.view</field>
            <field name="model">real.estate</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="date_show" widget="html"/>
                    <field name="code_demand_secondary_show" widget="html"/>
                    <field name="type_style_direction_show" widget="html"/>
<!--                    <field name="address_show" widget="html"/>-->
                    <field name="horizontal_length_use_area_show" widget="html"/>
                    <field name="total_price" />
                    <field name="structure_ids" widget="many2many_tags"/>
                    <field name="note"/>
                    <field name="deposit"/>
                    <field name="paid"/>
                    <field name="fee"/>
                </tree>
            </field>
        </record>

        <record id="real_estate_view_form" model="ir.ui.view">
        <field name="name">real.estate.view.form</field>
        <field name="model">real.estate</field>
        <field name="arch" type="xml">
            <form string="" >
                <header>
                    <button name="action_not_post" string="Chưa đăng bài" type="object" class="btn-primary" attrs="{'invisible': [('status_advertising', '==', 'not_post')]}"/>
                    <button name="action_stop_post" string="Ngưng đăng bài" type="object" class="btn-primary" attrs="{'invisible': [('status_advertising', 'in', ('stop_post','not_post'))]}"/>
                    <button name="action_posted" string="Đã đăng" type="object" class="btn-primary" attrs="{'invisible': [('status_advertising', '==', 'posted')]}"/>
                    <field name="status_advertising" widget="statusbar" statusbar_visible="not_post,stop_post,posted"/>
                </header>
                <sheet>
                    <group col="4">
                        <group>
                            <div>
                                <label for="code"  style="font-weight: bold;"/>
                                <h1><field name="code" required="1"/></h1>
                            </div>
                             <field name="image_avatar" invisible="1"/>
                            <field name="date_entry"/>
                            <field name="is_visiter"/>
                            
                            <button name="action_update_date_entry"
                                    type="object"
                                    icon="fa-refresh"
                                    class="o_reload_button"
                                    style="margin-left:100%"/>
                            <field name="date_fix" style="width: 90px !important; min-width: 90px !important;"/>
                            <field name="date_contract_exp"/>
                            <field name="user_id"/>
                            <field name="date_updated"/>
                            <field name="is_expired" invisible="1"/>
                        </group>
                        <group >
                        <button string="Chia sẽ" name="action_show_advertising_sample" type="object" class="oe_highlight" style="min-width:30px; min-height:30px;"/>
                            <field name="type_demand_id" style="width: 90px !important; min-width: 90px !important;" required="1"/>
                            <field name="secondary_form_id" required="1"/>
                            <field name="date_receive"/>
                            <field name="date_advertisement"/>
                        </group>
                        <group>
                            <field name="attachment_ids" widget="many2many_attachment_preview" style="width: 100px !important; min-width: 150px !important;"/>
                            <field name="source_image_partner_ids" widget="many2many_tags" style="width: 100px !important; min-width: 100px !important;"/>
                            <field name="source_image"/>
                            <field name="job_profession_id"/>
                            <field name="source_estate_partner_ids" widget="many2many_tags" domain="[('user_ids', '!=', False)]" style="width: 100px !important; min-width: 100px !important;"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Thông tin - Địa chỉ" name="information_address">
                            <group>
                                <group string="Địa chỉ">
                                    <field name="city_id"  required="0"  options="{'no_open': True,'no_create_edit': True, 'no_create': True }" attrs="{'invisible': [('is_visiter', '=', True)]}"/>
                                    <field name="district_id"  required="0"
                                             options="{'no_open': True,'no_create_edit': True, 'no_create': True }"
                                             domain="[('city_id', '=', city_id)]" attrs="{'invisible': [('is_visiter', '=', True)]}"/>
                                    <field name="ward_id"  required="0"
                                        attrs="{'invisible': [('is_visiter', '=', True)]}"
                                        options="{'no_open': True, 'no_create_edit': True, 'no_create': True }"
                                        domain="[('district_id', '=', district_id )]"/>

                                    <label for="street_id"  attrs="{'invisible': [('is_visiter', '=', True)]}" />
                                    <div colspan="1" attrs="{'invisible': [('is_visiter', '=', True)]}">
                                        <div><field name="number_house" placeholder="Số nhà"   nolabel="1"/></div>
                                        <div>
                                            <field name="street_id"  required="0"
                                                options="{'no_open': True, 'no_create_edit': True, 'no_create': True }"
                                                 class="street_select" placeholder="Chọn Đường" nolabel="1"
                                                 />
                                        </div>
                                    </div>
                                </group>
                                <group string="Vai trò">
                                    <button name="show_role_line"
                                            type="object"
                                            string="Vai trò"
                                            class="oe_highlight btn-rounded"
                                            icon="fa-phone"
                                        />
                                    <br/>
                                    <br/>
                                    <br/>
                                    <field name="role_line_ids" nolabel="1" attrs="{'invisible': [('show_hide_table_role', '=', True)]}" style="width:100" >
                                        <tree editable="bottom" limit="10">
                                            <field name="partner_id" required="1"/>
                                            <field name="role_detail_id"/>
                                        </tree>
                                    </field>
                                    <field name="show_hide_table_role" invisible="1"/>
                                </group>
                            </group>
                            <group col="4">
                                <group string="Kích thước">
                                    <field name="horizontal"/>
                                    <field name="length"/>
                                    <field name="acreage_area"/>
                                    <field name="acreage_use"/>
                                    <field name="bedroom"/>
                                </group>
                                <group string="Kết cấu">
                                    <field name="boundary_line" style="width: 110px !important; min-width: 110px !important;"/>
                                    <field name="direction_id"/>
                                    <field name="way_id"/>
                                    <field name="stair_id"/>
                                    <field name="kitchen"/>
                                </group>
                                <group string="   ">
                                    <br/>
                                    <field name="type_estate_id"/>
                                    <field name="style_id"/>
                                    <field name="structure_ids" widget="many2many_tags" style="width: 170px !important; min-width: 170px !important;"/>
                                    <field name="bathroom"/>
                                    <field name="is_elevator"/>
                                </group>
                            </group>
                            <group>
                                <group string="Giá cả">
                                    <field name="total_price"/>
                                    <field name="currency_id"/>
                                </group>
                                <group string="  ">
                                    <br/>
                                    <field name="fee"/>
                                    <field name="fee_unit"/>
                                    <field name="deposit"/>
                                    <field name="paid"/>
                                </group>
                            </group>
                            <notebook>
                                <page string="Ghi chú">
                                    <field name="note"/>
                                </page>
                                <page string="Tài liệu">
                                    <group>
                                        <field name="pink_book_attachment_ids" widget="many2many_attachment_preview"/>
                                        <field name="contract_attachment_ids" widget="many2many_attachment_preview"/>
                                        <field name="document_attachment_ids" widget="many2many_attachment_preview"/>
                                    </group>
                                </page>
                                <page string="Yêu cầu phụ">
                                    <field name="child_ids" nolabel="1" >
                                        <tree>
                                            <field name="date_entry"/>
                                            <field name="code_demand_secondary_show" widget="html"/>
                                            <field name="type_style_direction_show" widget="html"/>
                                            <field name="number_house"/>
                                            <field name="street_id"/>
                                            <field name="address_ward_district_show"/>
        <!--                                    <field name="district_id"/>-->
                                            <field name="horizontal_length_use_area_show" widget="html"/>
                                            <field name="total_price" />
                                            <field name="structure_ids" widget="many2many_tags"/>
                                            <field name="note"/>
                                            <field name="deposit"/>
                                            <field name="paid"/>
                                            <field name="fee"/>
                                        </tree>
                                    </field>
                                </page>
                            </notebook>

                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>



        <record id="real_estate_action" model="ir.actions.act_window">
            <field name="name">Nhà đất</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">real.estate</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'form_view_initial_mode': 'edit'}</field>
        </record>

        <record model="ir.actions.act_window" id="action_create_real_estate">
			 <field name="name">Tạo mới nhà đất</field>
			 <field name="res_model">real.estate</field>
<!--            <field name="view_type">form</field>-->
            <field name="view_mode">form</field>
            <field name="view_id" ref="fs_real_estate.real_estate_view_form"/>
            <field name="target">new</field>
		 </record>


    </data>
</odoo>