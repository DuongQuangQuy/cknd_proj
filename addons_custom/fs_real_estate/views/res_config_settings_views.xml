<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.real.estate</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('settings')]" position="inside">
                    <div class="app_settings_block" data-string="Real Estate" id="real_estate" string="Real Estate" data-key="fs_real_estate">
                        <h2>Vận tải</h2>
                        <div class="row mt16 o_settings_container" id="cost_xlhn_setting">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <div class="content-group">
                                        <div class="row mt16">
                                            <div class="col-lg-6 o_light_label">
                                                <label for="number_exp"/>
                                            </div>
                                            <div class="col-lg-6">
                                                <field name="number_exp"/>
<!--                                                <field name="currency_id" required="1" options="{'no_create': True, 'no_open': True}"/>-->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>

